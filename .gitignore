# 密钥 / 凭据 / 证书 —— 绝不入库
.env
*.env
!*.env.example
secrets/
*.key
*.pem
*.crt
*.csr

# Authelia 运行时与敏感数据
server/authelia/secrets/
server/authelia/db.sqlite3
server/authelia/notification.txt
server/authelia/users_database.yml          # 含密码哈希，用 .example 入库
!server/authelia/users_database.yml.example

# Headscale 运行时（真实 config 含路径/可能私钥；模板入库）
server/headscale/config.yaml
server/headscale/*.key
server/headscale/*.sqlite*

# Filebrowser 数据库
**/filebrowser.db
**/.macfleet-filebrowser.db

# fleet-agent：源码与预编译二进制(dist/)入库；仅忽略本地临时产物
mac/fleet-agent/fleet-agent
/tmp/

# Claude Code 本地配置（机器专属，不入库；人格 .claude/commands 与 .agents 记忆入库）
.claude/settings.local.json

# 系统杂项
.DS_Store
*.log
