# 复制为 server/.env 并填写真实值（.env 已被 .gitignore 排除）。
# 这台网关 = Ubuntu（user，需 sudo）；公网入口 https://mfh.example.com:20443/

# 根域名（通配符证书 *.example.com 的注册域）
DOMAIN=example.com
# 服务对外子域：web 入口 + Headscale 控制面都用它（需已做 DNS 解析到本网关公网 IP）
FLEET_HOST=mfh.example.com

# 通配符证书 *.example.com（acme.sh 签发的 ECC 证书；nginx + headscale 共用同一对）。
# nginx/headscale 需完整链 → 用 fullchain.cer（非 example.com.cer，后者缺中间 CA）；私钥用 .key。
# 注：直接引用 ~/.acme.sh 内部文件，acme.sh 升级目录可能变；更稳妥可 `acme.sh --install-cert`
#     部署到固定路径（并配 reloadcmd: nginx -s reload && systemctl reload headscale）再指过去。
SSL_CERT=/root/.acme.sh/example.com_ecc/fullchain.cer
SSL_KEY=/root/.acme.sh/example.com_ecc/example.com.key

# 公网入口端口（路由把 20443→本机443；Headscale 28443→本机8443）
GATEWAY_PORT=20443
HEADSCALE_PUBLIC_PORT=28443
HEADSCALE_LISTEN_PORT=8443

# 三台 Mac 的 Headscale mesh IP（各 Mac 上 `tailscale ip -4` 查；setup-mac.sh 会打印）
MAC1_IP=100.64.0.1
MAC2_IP=100.64.0.2
MAC3_IP=100.64.0.3

# Mac 服务端口（与 mac/setup-mac.sh 一致）
TTYD_PORT=7681
FB_PORT=8080
AGENT_PORT=7682

# 输出的独立 nginx 站点文件（mfh.example.com 的 server 块，由 setup-server.sh 写入；与现有 rtm 应用互不影响）
NGINX_SITE=/etc/nginx/sites-enabled/mac-fleet-hub.conf
