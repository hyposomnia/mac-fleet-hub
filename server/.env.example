# 复制为 server/.env 并填写真实值（.env 已被 .gitignore 排除）。
# 这台网关 = Ubuntu（sudo 用户）；公网入口 https://fleet.example.com/

# 根域名（通配符证书 *.example.com 的注册域）
DOMAIN=example.com
# 服务对外子域：web 入口 + Headscale 控制面都用它（需已做 DNS 解析到本网关公网 IP）
FLEET_HOST=fleet.example.com

# 通配符证书 *.example.com（acme.sh 签发的 ECC 证书；nginx + headscale 共用同一对）。
# nginx/headscale 需完整链 → 用 fullchain.cer（非 example.com.cer，后者缺中间 CA）；私钥用 .key。
# 注：直接引用 ~/.acme.sh 内部文件，acme.sh 升级目录可能变；更稳妥可 `acme.sh --install-cert`
#     部署到固定路径（并配 reloadcmd: nginx -s reload && systemctl reload headscale）再指过去。
SSL_CERT=/root/.acme.sh/example.com_ecc/fullchain.cer
SSL_KEY=/root/.acme.sh/example.com_ecc/example.com.key

# 对外端口 = 访问 URL 里的端口（与本机实际监听解耦）。默认走标准端口、不需要任何 NAT：
#   GATEWAY_PORT          web 入口对外端口（nginx 内部恒听 443）。默认 443。
#   HEADSCALE_PUBLIC_PORT Headscale 控制面对外端口。默认 = 监听端口。
#   HEADSCALE_LISTEN_PORT Headscale 本机实际监听端口。默认 8443（避开 nginx 占用的 443）。
# 当对外端口 = 标准 443 时，脚本生成的 URL 会自动省略端口（https://host/ 而非 host:443）。
#
# 仅当你的网络封了 80/443（例如部分家庭宽带）才需要高位端口 + 路由器 NAT 端口映射，例如：
#   GATEWAY_PORT=20443          且在路由器把 公网20443 → 本机443
#   HEADSCALE_PUBLIC_PORT=28443 且在路由器把 公网28443 → 本机8443
# 此时 setup-server.sh 会自动加一条 DERP 回环重定向解决网关 hairpin（仅在对外≠监听端口时启用）。
GATEWAY_PORT=443
HEADSCALE_PUBLIC_PORT=8443
HEADSCALE_LISTEN_PORT=8443

# 各 Mac 的 Headscale mesh IP —— 空格分隔，可任意台数（按顺序对应 m1 m2 m3 …，
# 即第 1 个 IP = mac1、第 2 个 = mac2，依此类推）。setup-server.sh 据此循环生成
# 每台的 nginx 反代块；dashboard 则按已入网节点名 mac<N> 动态枚举。
# 各 Mac 上用 `tailscale ip -4` 查（setup-mac.sh 也会打印）。示例为两台：
MAC_IPS=100.64.0.1 100.64.0.2

# Mac 服务端口（与 mac/setup-mac.sh 一致）
TTYD_PORT=7681
FB_PORT=8080
AGENT_PORT=7682

# 输出的独立 nginx 站点文件（fleet.example.com 的 server 块，由 setup-server.sh 写入；与其它站点互不影响）
NGINX_SITE=/etc/nginx/sites-enabled/mac-fleet-hub.conf
