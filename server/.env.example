# 复制为 server/.env 并填写真实值（.env 已被 .gitignore 排除）。
# 这台网关 = Ubuntu（user，需 sudo）；公网入口 https://example.com:20443/fleet/

# 根域名（现有 nginx 已有该域 LE 证书）
DOMAIN=example.com

# 公网入口端口（路由把 20443→本机443；Headscale 28443→本机8443）
GATEWAY_PORT=20443
HEADSCALE_PUBLIC_PORT=28443
HEADSCALE_LISTEN_PORT=8443

# 三台 Mac 的 Headscale mesh IP（各 Mac 上 `tailscale ip -4` 查；setup-mac.sh 会打印）
MAC1_IP=100.64.0.1
MAC2_IP=100.64.0.2
MAC3_IP=100.64.0.3

# Mac 服务端口（与 mac/setup-mac.sh 一致）
TTYD_PORT=7681
FB_PORT=8080
AGENT_PORT=7682

# 现有 nginx：要把 fleet.conf include 进哪个站点配置（含 example.com 的 443 server 块）
NGINX_SITE=/etc/nginx/sites-enabled/rtm.conf
