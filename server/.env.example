# 复制为 .env 并填写真实值（.env 已被 .gitignore 排除）

# 你的根域名（需把 *.DOMAIN 解析到本服务器公网 IP）
DOMAIN=example.com

# 用于申请通配证书的 DNS 提供商 API（Caddy DNS challenge）。
# 例：Cloudflare → CF_API_TOKEN。不同 DNS 商参数不同，按需调整。
CF_API_TOKEN=changeme

# 三台 Mac 在 Tailscale 内网的 IP（tailscale ip -4 在各 Mac 上查）
MAC1_IP=100.x.x.1
MAC2_IP=100.x.x.2
MAC3_IP=100.x.x.3

# Mac 上服务端口（与 mac/setup-mac.sh 保持一致）
TTYD_PORT=7681
FB_PORT=8080

# 共享目录（服务器上由 Syncthing 同步、由 Filebrowser 暴露）
SHARED_DIR=/root/Shared
