# Caddyfile —— 公网网关：通配 TLS + Authelia 2FA + 反代到各 Mac(经 Tailscale 内网)
#
# 占位符 {$DOMAIN} {$MAC1_IP} 等由 docker-compose 的环境变量注入(来自 .env)。
# DNS challenge 需要 caddy-dns 插件(见 docker-compose 注释)。

{
	# 全局：可选邮箱用于 ACME 通知
	# email you@{$DOMAIN}
}

# ---------- 复用片段 ----------
# 每个受保护站点都先 forward_auth 到 Authelia，未登录则跳转门户
(authelia) {
	forward_auth authelia:9091 {
		uri /api/authz/forward-auth
		copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
	}
}

# 通配证书（一次签发覆盖所有子域）
*.{$DOMAIN} {
	tls {
		dns cloudflare {$CF_API_TOKEN}   # 换成你的 DNS 商
	}

	# --- Authelia 登录门户 ---
	@auth host auth.{$DOMAIN}
	handle @auth {
		reverse_proxy authelia:9091
	}

	# --- 各 Mac 网页终端(ttyd) ---
	@term1 host term1.{$DOMAIN}
	handle @term1 {
		import authelia
		reverse_proxy {$MAC1_IP}:{$TTYD_PORT}
	}
	@term2 host term2.{$DOMAIN}
	handle @term2 {
		import authelia
		reverse_proxy {$MAC2_IP}:{$TTYD_PORT}
	}
	@term3 host term3.{$DOMAIN}
	handle @term3 {
		import authelia
		reverse_proxy {$MAC3_IP}:{$TTYD_PORT}
	}

	# --- 各 Mac 文件管理(Filebrowser) ---
	@files1 host files1.{$DOMAIN}
	handle @files1 {
		import authelia
		reverse_proxy {$MAC1_IP}:{$FB_PORT}
	}
	@files2 host files2.{$DOMAIN}
	handle @files2 {
		import authelia
		reverse_proxy {$MAC2_IP}:{$FB_PORT}
	}
	@files3 host files3.{$DOMAIN}
	handle @files3 {
		import authelia
		reverse_proxy {$MAC3_IP}:{$FB_PORT}
	}

	# --- 服务器共享目录(三台 Syncthing 同步) ---
	@shared host shared.{$DOMAIN}
	handle @shared {
		import authelia
		reverse_proxy filebrowser:80
	}

	# 兜底：未匹配的子域返回 404
	handle {
		respond "not found" 404
	}
}

# reverse_proxy 默认已透传 WebSocket 升级头，ttyd/Filebrowser 的 ws 可直接工作。
