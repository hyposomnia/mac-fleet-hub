# Headscale 配置模板 —— 复制为 config.yaml 部署到 /etc/headscale/config.yaml
# 占位 {{FLEET_HOST}} 由 scripts/setup-server.sh 用 .env 的 FLEET_HOST 替换。
# 完整字段参考官方 config-example.yaml；这里只列与本方案相关的关键项。

# 客户端连这个对外地址（占位 {{HS_BASE}} = https://FLEET_HOST[:HEADSCALE_PUBLIC_PORT]，
# 对外用标准 443 时省略端口）。默认无 NAT 时对外端口 = 监听端口 8443。
server_url: {{HS_BASE}}

# 本机实际监听端口（占位 {{HEADSCALE_LISTEN_PORT}}，默认 8443，避开 nginx 的 443）。
# 若做了 NAT（对外 28443 → 本机 8443），监听仍是 8443、对外端口在 .env 设。直接用 LE 证书自带 TLS。
listen_addr: 0.0.0.0:{{HEADSCALE_LISTEN_PORT}}
metrics_listen_addr: 127.0.0.1:9090

# 复用 nginx 用的同一张通配符证书（按 host 生效、与端口无关）。占位 {{SSL_CERT}}/{{SSL_KEY}}
# 由 setup-server.sh 用 .env 的 SSL_CERT/SSL_KEY 替换（与 nginx 单一来源，不会不一致）。
# headscale 以 root 运行以读取证书/私钥（见 systemd 单元；acme.sh 目录默认 root-only）。
tls_cert_path: {{SSL_CERT}}
tls_key_path: {{SSL_KEY}}

# 不让 headscale 自己管 ACME（证书由 certbot 管）。
tls_letsencrypt_hostname: ""

noise:
  private_key_path: /var/lib/headscale/noise_private.key

prefixes:
  v4: 100.64.0.0/10
  v6: fd7a:115c:a1e0::/48
  allocation: sequential

# 自托管 DERP（中继也归自己，彻底零 SaaS）。关闭官方 DERP。
derp:
  server:
    enabled: true
    region_id: 999
    region_code: "fleet"
    region_name: "mac-fleet-hub embedded DERP"
    stun_listen_addr: "0.0.0.0:3478"
    private_key_path: /var/lib/headscale/derp_server_private.key
  urls: []
  paths: []
  auto_update_enabled: false

database:
  type: sqlite
  sqlite:
    path: /var/lib/headscale/db.sqlite

# MagicDNS：给节点 mac1/mac2/mac3 等名字，nginx 也可用名字反代（可选）。
dns:
  magic_dns: true
  base_domain: fleet.internal
  nameservers:
    global:
      - 1.1.1.1
      - 223.5.5.5

# ACL 策略文件（见 acl.hujson）。
policy:
  mode: file
  path: /etc/headscale/acl.hujson

log:
  level: info

# 预授权 key、用户由 setup-server.sh 用 `headscale users create` / `headscale preauthkeys create` 生成。
